    <ui:MultiColumnListView name="attribute-values" virtualization-method="FixedHeight" fixed-item-height="24" show-foldout-header="true" header-title="Attribute Values" show-add-remove-footer="false" show-bound-collection-size="false" binding-source-selection-mode="AutoAssign" show-border="false" sorting-mode="None" class="attribute-definition">
