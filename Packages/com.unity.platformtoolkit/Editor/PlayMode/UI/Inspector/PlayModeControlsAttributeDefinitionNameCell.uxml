<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <engine:TextField placeholder-text="Attribute Name" class="attribute-definition__cell">
        <Bindings>
            <engine:DataBinding property="value" data-source-path="Name"/>
        </Bindings>
    </engine:TextField>
</engine:UXML>
