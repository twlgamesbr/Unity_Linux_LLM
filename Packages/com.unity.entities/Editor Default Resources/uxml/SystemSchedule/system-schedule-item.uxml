<UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements">
    <ui:VisualElement class="system-schedule-item__container">
        <ui:VisualElement name="Column System Name" class="system-schedule-item__column-system-name">
            <ui:VisualElement name="Icon" class="system-schedule-item__icon"/>
            <ui:Label name="Name" class="system-schedule-item__name-label" display-tooltip-when-elided="true"/>
        </ui:VisualElement>
    </ui:VisualElement>
</UXML>
