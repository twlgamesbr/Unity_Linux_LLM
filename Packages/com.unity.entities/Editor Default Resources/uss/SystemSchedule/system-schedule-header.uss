
.system-schedule-treeview-header {
    justify-content: flex-start;
    align-items: center;
    padding-right: 10px;
}

.system-schedule-header {
    flex-direction: row;
}

.system-schedule-header__system-label {
    padding-left: 25px;
    flex-shrink: 1;
    flex-grow: 1;
    width: 200px;
    text-overflow: ellipsis;
    flex-direction: row;
    overflow: hidden;
    min-width: 0;
}

.system-schedule-header__world-label {
    width: 120px;
    border-left-width: 1px;
    -unity-text-align: middle-left;
    padding-left: 6px;
    text-overflow: ellipsis;
    flex-direction: row;
    overflow: hidden;
    min-width: 0;
    flex-shrink: 1;
    flex-grow: 1;
}

.system-schedule-header__namespace-label {
    width: 250px;
    border-left-width: 1px;
    -unity-text-align: middle-left;
    padding-left: 6px;
    text-overflow: ellipsis;
    flex-direction: row;
    overflow: hidden;
    min-width: 0;
    flex-shrink: 1;
    flex-grow: 1;
}

.system-schedule-header__entity-count-label {
    width: 90px;
    border-left-width: 1px;
    -unity-text-align: middle-left;
    padding-left: 6px;
    text-overflow: ellipsis;
    flex-direction: row;
    overflow: hidden;
    min-width: 0;
    flex-shrink: 1;
    flex-grow: 1;
}

.system-schedule-header__time-label {
    width: 65px;
    border-left-width: 1px;
    -unity-text-align: middle-left;
    padding-left: 6px;
    text-overflow: ellipsis;
    flex-direction: row;
    min-width: 0;
    flex-shrink: 1;
    flex-grow: 1;
}
