const functionsFilePath = !Module['ENVIRONMENT_IS_PTHREAD'] ? "Build/functions.json" : "functions.json";
const labelsFilePath = !Module['ENVIRONMENT_IS_PTHREAD'] ? "Build/labels.json" : "labels.json";
var _calledFunctions = new Set();
var _usedLabels = new Set();
var _labelMap = null;
var _availableSubmodules = null;
var _functionMap = null;

function _log_execution(funcId, labelId) {
  _calledFunctions.add(funcId);
  _usedLabels.add(labelId);
}

function _difference(a, b) {
  // Use builtin function if present
  if (typeof a.difference === "function") {
    return a.difference(b);
  }

  const diff = new Set();
  for (let element of a) {
    if (!b.has(element))
        diff.add(element);
  }

  return diff;
}

async function _getFunctionMap() {
  if (_functionMap != null)
    return _functionMap;

  let response = await fetch(functionsFilePath);
  _functionMap = await response.json();

  return _functionMap;
}

async function _getLabelMap() {
  if (_labelMap != null)
    return _labelMap;

  let response = await fetch(labelsFilePath)
  _labelMap = await response.json();
  _availableSubmodules = _parseAvailableSubmodules(_labelMap);

  return _labelMap;
}

function _parseAvailableSubmodules(labelMap) {
  let labels = Object.values(labelMap);
  let availableSubmodules = new Set();

  for (let label of labels) {
    let submodules = label.split(",");
    for (let submodule of submodules) {
      availableSubmodules.add(submodule);
    }
  }

  return availableSubmodules;
}

async function _getUnusedSubmodules() {
  await _getLabelMap();

  let usedSubmodules = new Set();
  for (let labelId of _usedLabels) {
    let submodules = _labelMap[labelId].split(",");
    for (let submodule of submodules) {
      usedSubmodules.add(submodule);
    }
  }

  let unusedSubmodules = _difference(_availableSubmodules, usedSubmodules);

  return unusedSubmodules;
}

async function _getSubmoduleReport() {
  await _getLabelMap();
  await _getFunctionMap();
  
  const submoduleReport = {
    submodules: {},
    calledFunctions: []
  };

  // Set all available submodule as unused initially
  for (var submodule of _availableSubmodules) {
    submoduleReport.submodules[submodule] = false;
  }

  // Set submodules as used according to used labels
  for (let labelId of _usedLabels) {
    let submodules = _labelMap[labelId].split(",");
    for (let submodule of submodules) {
      submoduleReport.submodules[submodule] = true;
    }
  }

  // Create list of called functions
  for (let funcId of _calledFunctions) {
    submoduleReport.calledFunctions.push(_functionMap[funcId]);
  }

  return submoduleReport;
}

async function _createAndDownloadSubmoduleReport() {
  const submoduleReport = await _getSubmoduleReport();
  const blob = new Blob([JSON.stringify(submoduleReport)], { type: 'application/json' });
  const link = document.createElement('a');
  link.href = URL.createObjectURL(blob);
  link.download = 'submodule_report.json';
  link.click();
}

function _addSubmoduleProfilingOverlay() {
  let unityFooter = document.getElementById("unity-footer");
  if (!unityFooter) {
    unityFooter = document.createElement("div");
    unityFooter.id = "unity-footer";
    unityFooter.style = "position: fixed; bottom: 20px; right: 20px; background-color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; justify-content: center; align-items: center; cursor: pointer; z-index: 1000;";
    document.body.appendChild(unityFooter);
  }

  const submoduleProfilingContainer = document.createElement("div");
  submoduleProfilingContainer.id = "submodule-profiling-overlay";
  submoduleProfilingContainer.style = "resize: vertical; overflow: auto; position:fixed; left:0px; bottom:0px; height:20%; width:100%; color: #090909; background:rgba(200, 200, 200, .90); display: none; align-items: stretch; z-index: 1000;";
  document.body.appendChild(submoduleProfilingContainer);

  const profilingButton = document.createElement("img");
  profilingButton.id = "submodule-profiling-button";
  profilingButton.src = "TemplateData/submodule-profiling-icon.png";
  profilingButton.title = "Open Submodule Profiling Overlay";
  profilingButton.style = "display: flex; float: right; width:38px; height: 38px; cursor:pointer;";
  profilingButton.addEventListener("click", () => {
    submoduleProfilingContainer.style.display = "flex";
  });
  unityFooter.appendChild(profilingButton);

  const closeButton = document.createElement("div");
  closeButton.id = "submodule-profiling-close-button";
  closeButton.innerHTML = "X";
  closeButton.title = "Close Submodule Profiling Overlay";
  closeButton.style = "float: left; font-family: arial; display: flex; justify-content: center; align-items: center; border: 1px solid #CCC; background: #DDD; box-shadow: 0 0 5px -1px rgba(0,0,0,0.2); cursor: pointer; width: 38px; height: 38px;";
  closeButton.addEventListener("click", () => {
    submoduleProfilingContainer.style.display = "none";
  });
  submoduleProfilingContainer.appendChild(closeButton);

  const diagnosticsSummary = document.createElement("div");
  diagnosticsSummary.id = "submodule-profiling-summary";
  diagnosticsSummary.style = "display: inline-flex; font-family: arial; flex-flow: column; column-gap: 1em; margin: 1em; padding: 1em; max-width: 33em; row-gap: 0.2em; width: 20%; resize: horizontal; float: left; min-width: fit-content; height: 60%;";
  submoduleProfilingContainer.appendChild(diagnosticsSummary);

  const dataRow = document.createElement("div");
  dataRow.className = "data-row";
  dataRow.style = "display: flex;";
  diagnosticsSummary.appendChild(dataRow);

  const label = document.createElement("div");
  label.innerHTML = "Unused Submodules";
  label.className = "label";
  label.style = "display: flex; flex: 2 1 auto;";
  dataRow.appendChild(label);

  const data = document.createElement("div");
  data.className = "data";
  data.style = "display: flex; flex: 1 1 auto; justify-content: right;";
  dataRow.appendChild(data);

  const buttonRow = document.createElement("div");
  buttonRow.className = "data-row";
  buttonRow.style = "display: flex; margin-top: 0.5em;";
  diagnosticsSummary.appendChild(buttonRow);

  const downloadButton = document.createElement("button");
  downloadButton.textContent = "Download Report";
  downloadButton.style = "float: left; font-family: arial; display: flex; justify-content: center; align-items: center; border: 1px solid #CCC; background: #DDD; box-shadow: 0 0 5px -1px rgba(0,0,0,0.2);";
  downloadButton.addEventListener("click", () => _createAndDownloadSubmoduleReport());
  buttonRow.appendChild(downloadButton);

  async function updateOverlay() {
    const unusedSubmodules = await _getUnusedSubmodules();

    data.innerHTML = `${unusedSubmodules.size} / ${_availableSubmodules.size}`;

    setTimeout(updateOverlay, 1000);
  }
  updateOverlay();
}
if (!Module['ENVIRONMENT_IS_PTHREAD']) {
  _addSubmoduleProfilingOverlay();
}

var wasmImports = {
  "log_execution": _log_execution,