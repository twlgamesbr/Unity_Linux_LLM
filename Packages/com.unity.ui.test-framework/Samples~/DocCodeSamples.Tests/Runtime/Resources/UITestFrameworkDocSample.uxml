<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:ScrollView name="MyScrollView">
        <ui:Label text="Label" name="MyLabelWithBindings"/>
        <ui:Button text="Button" name="MyButton"/>
        <ui:TextField label="Text Field" placeholder-text="filler text" name="MyTextField"/>
        <ui:DropdownField label="Dropdown" choices="Option1,Option2" name="MyDropdownField"/>
        <ui:Slider label="Slider" value="42" high-value="100" name="MySlider"/>
        <ui:VisualElement style="flex-grow: 1;">
            <ui:Label text="Label text label text label text" selectable="true" focusable="true" name="MyLabel" style="font-size: 246px; white-space: pre-wrap;"/>
        </ui:VisualElement>
    </ui:ScrollView>
</ui:UXML>
