{
  "mcpServers": {
    "chrome-devtools-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://127.0.0.1:9222"
      ],
      "env": {
        "CHROME_PATH": "/home/athar/.gemini/antigravity/scratch/chrome-wrapper",
        "PUPPETEER_EXECUTABLE_PATH": "/home/athar/.gemini/antigravity/scratch/chrome-wrapper"
      }
    },
    "gladekit-unity": {
      "command": "uvx",
      "args": [
        "gladekit-mcp"
      ]
    },
    "datadog": {
      "command": "npx",
      "args": [
        "datadog-mcp@latest",
        "--url=https://mcp.us5.datadoghq.com/v1/mcp"
      ],
      "env": {
        "DD_API_KEY": "5cc57a1d-3b22-4a13-9c0c-e243cd1d811e",
        "DD_APP_KEY": "e6146ab1-56fd-4c96-9347-2391d4f2fe62"
      }
    },
    "unity-mcp": {
      "command": "/home/athar/.unity/relay/relay_linux",
      "args": [
        "--mcp"
      ],
      "env": {}
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "notebooks": {
      "command": "node",
      "args": [
        "/home/athar/.antigravity-ide/extensions/googlecloudtools.datacloud-0.6.1-universal/mcp_servers/cli/mcp_proxy_bundle.js",
        "notebooks-antigravityide"
      ]
    },
    "visualization": {
      "command": "node",
      "args": [
        "/home/athar/.antigravity-ide/extensions/googlecloudtools.datacloud-0.6.1-universal/mcp_servers/cli/mcp_proxy_bundle.js",
        "visualization-antigravityide"
      ]
    }
  }
}
