# ─────────────────────────────────────────────────
DD_API_KEY=your_datadog_api_key_here
DD_SITE=datadoghq.com

# For EU region users, use:
# DD_SITE=datadoghq.eu

# For US5 region users, use:
# DD_SITE=us5.datadoghq.com
