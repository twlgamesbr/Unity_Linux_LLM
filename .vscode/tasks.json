{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Unity: Build Scripts (check compilation)",
            "type": "shell",
            "command": "dotnet build",
            "args": [
                "--no-restore",
                "--nologo",
                "-v", "q",
                "-p:WarningLevel=0"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "silent",
                "close": true,
                "panel": "shared"
            }
        },
        {
            "label": "Codebase: Scan",
            "type": "shell",
            "command": "uv",
            "args": ["run", "--directory", "Tools/CodebaseEmbedder", "codebase-embedder", "scan", "--root", "${workspaceFolder}"],
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Codebase: Check Rules",
            "type": "shell",
            "command": "uv",
            "args": ["run", "--directory", "Tools/CodebaseEmbedder", "codebase-embedder", "check", "--root", "${workspaceFolder}"],
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Codebase: Index (embed + upsert)",
            "type": "shell",
            "command": "uv",
            "args": ["run", "--directory", "Tools/CodebaseEmbedder", "codebase-embedder", "index", "--root", "${workspaceFolder}"],
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Codebase: Status",
            "type": "shell",
            "command": "uv",
            "args": ["run", "--directory", "Tools/CodebaseEmbedder", "codebase-embedder", "status", "--root", "${workspaceFolder}"],
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Unity: Format (CSharpier)",
            "type": "shell",
            "command": "dotnet",
            "args": ["csharpier", "."],
            "group": "none",
            "problemMatcher": []
        }
    ]
}
