<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:tns="Unity.PlatformToolkit.PlayMode" elementFormDefault="qualified" targetNamespace="Unity.PlatformToolkit.PlayMode" xmlns:xs="http://www.w3.org/2001/XMLSchema">
