        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:element minOccurs="0" maxOccurs="1" form="unqualified" name="value" type="tns:TimeDropdownvalueType" />
        </xs:choice>
        <xs:attribute name="label" type="xs:string" />
        <xs:attribute name="formatting-prefix" type="xs:string" />
